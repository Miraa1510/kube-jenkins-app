pipeline{
    agent any
    tools {
            jdk 'JDK25'   // matches the name you configured in Jenkins
            maven 'Maven3' // if you configured Maven in Jenkins too
        }
    stages{
        stage("checkout"){
            steps{
            retry(3){
               git "https://github.com/Miraa1510/kube-jenkins-app.git"
               }
            }
        }
        stage("compile"){
            steps{
            bat "mvn clean compile"
            }
        }

         stage("package"){
            steps{
            bat "mvn package"
            }
        }
       stage("docker build"){
                   steps{
                   bat "docker build -t kube-jenkins-app:%BUILD_NUMBER% ."
                   }
               }
        }

}